# Copy this file to .env and fill in the values.
# Do not commit .env.

# Required for running migrations (npm run migrate).
# Get it from: Supabase Dashboard → Project Settings → Database → Connection string (URI).
# Use either Direct Connection or Pooler Connection.
# Direct Connection:
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Pooler Connection:
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:5432/postgres
